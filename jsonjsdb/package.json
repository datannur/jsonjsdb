{
  "name": "jsonjsdb",
  "version": "0.12.6",
  "description": "Jsonjsdb database",
  "type": "module",
  "license": "MIT",
  "author": "Bassim Matar",
  "keywords": [
    "json",
    "database",
    "jsondb",
    "jsonjsdb",
    "local",
    "file protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datannur/jsonjsdb.git#main",
    "directory": "jsonjsdb"
  },
  "homepage": "https://github.com/datannur/jsonjsdb/tree/main/jsonjsdb#readme",
  "main": "dist/jsonjsdb.esm.js",
  "module": "dist/jsonjsdb.esm.js",
  "exports": {
    ".": {
      "types": "./dist/Jsonjsdb.d.ts",
      "import": "./dist/jsonjsdb.esm.js",
      "default": "./dist/jsonjsdb.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "types": "dist/Jsonjsdb.d.ts",
  "typings": "dist/Jsonjsdb.d.ts",
  "scripts": {
    "build": "vite build",
    "postbuild": "node -e \"const t=require('./package.json').types;if(!require('fs').existsSync(t)){console.error('declared types file missing from build output: '+t);process.exit(1)}\"",
    "dev": "vitest",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "playwright": "^1.60.0",
    "terser": "^5.48.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  }
}
